---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqList from "../../components/FaqList.astro";
import LeadForm from "../../components/LeadForm.astro";
import ProductCard from "../../components/ProductCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { generatorComparisons, products } from "../../data/catalog";
import { buildWhatsAppUrl, generatorFaqs } from "../../data/site";
import {
  breadcrumbSchema,
  faqSchema,
  itemListSchema,
  organizationSchema,
  serviceSchema,
  webPageSchema,
  websiteSchema,
} from "../../data/schema";

const whatsappUrl = buildWhatsAppUrl("Hola, necesito una cotización de un generador Generax.");
const schema = [
  organizationSchema(),
  websiteSchema(),
  webPageSchema(
    "Generadores industriales | GENERAX",
    "Venta de generadores eléctricos industriales y comerciales en México. Equipos diésel y gas para respaldo, operación continua y proyectos especiales.",
    "/generadores/",
    "CollectionPage",
  ),
  breadcrumbSchema([
    { name: "Inicio", path: "/" },
    { name: "Generadores", path: "/generadores/" },
  ]),
  serviceSchema(
    "Generadores eléctricos industriales en México",
    "Catálogo consultivo de generadores eléctricos para respaldo, operación crítica e infraestructura industrial.",
    "/generadores/",
  ),
  faqSchema(generatorFaqs),
  itemListSchema(
    "Catálogo de generadores GENERAX",
    products.map((product) => ({
      name: product.shortName,
      path: `/generadores/${product.routeSlug}/`,
    })),
  ),
];
---

<BaseLayout
  title="Generadores industriales | GENERAX"
  description="Venta de generadores eléctricos industriales y comerciales en México. Equipos diésel y gas para respaldo, operación continua y proyectos especiales."
  path="/generadores/"
  image="/media/Generador-Generax-12.jpeg"
  imageAlt="Generador Generax industrial para catálogo B2B"
  schema={schema}
>
  <section class="page-hero">
    <div class="container page-hero__grid">
      <div class="page-hero__copy">
        <div class="breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>Generadores</span>
        </div>
        <span class="hero__eyebrow">Generadores eléctricos</span>
        <h1>Generadores eléctricos industriales en México.</h1>
        <p>
          Equipos para energía de respaldo y operación continua en industria, comercio, hotelería, salud, logística y
          proyectos especiales.
        </p>
        <div class="hero__actions">
          <a
            class="button button--primary"
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            data-whatsapp-context="generadores-hero-primary"
          >
            Cotizar por WhatsApp
          </a>
          <a class="button button--ghost" href="#catalogo-generadores">
            Ver catálogo
          </a>
        </div>
        <ul class="clean-list">
          <li>Capacidades desde 20 kW hasta 500 kW.</li>
          <li>Opciones diésel y gas LP / natural según la operación.</li>
          <li>Tablero automático, ATS y configuraciones comerciales a medida.</li>
        </ul>
      </div>

      <div class="page-hero__card hero__visual">
        <img
          src="/media/Generador-Generax-12.jpeg"
          alt="Generador Generax industrial para catálogo B2B"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section id="catalogo-generadores" class="section-block section-block--light light-surface">
    <div class="container content-grid">
      <article class="content-panel">
        <SectionHeading
          eyebrow="Cómo elegir"
          title="Capacidad, combustible y forma de operación."
          intro="La selección correcta depende de la carga, la autonomía esperada y el impacto que una falla eléctrica tiene sobre tu operación."
        />
        <div class="comparison-list">
          {
            generatorComparisons.map((item) => (
              <article>
                <h3>{item.label}</h3>
                <p>{item.details}</p>
              </article>
            ))
          }
        </div>
      </article>

      <LeadForm
        compact={true}
        source="generadores-sidebar"
        title="Solicita una cotización de generador"
        intro="Compártenos capacidad aproximada, combustible y tipo de operación para orientarte mejor."
      />
    </div>
  </section>

  <section class="section-block section-block--light light-surface">
    <div class="container">
      <SectionHeading
        eyebrow="Catálogo"
        title="Catálogo de generadores"
        intro="Consulta las capacidades disponibles y solicita atención comercial para tu proyecto."
      />
      <div class="catalog-grid">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section-block section-block--light light-surface">
    <div class="container">
      <SectionHeading
        eyebrow="FAQ de decisión"
        title="Dudas frecuentes antes de cotizar."
        intro="Resolvemos preguntas comunes sobre selección, combustible, transferencia y operación."
      />
      <FaqList items={generatorFaqs} />
    </div>
  </section>
</BaseLayout>
