---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LeadForm from "../../components/LeadForm.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buildWhatsAppUrl, industrySolutions } from "../../data/site";
import { breadcrumbSchema, organizationSchema, serviceSchema, webPageSchema, websiteSchema } from "../../data/schema";

const solutionModes = [
  {
    title: "Respaldo de emergencia",
    body: "Para operaciones que deben entrar en segundos al perder red: salud, hotelería, retail y sitios críticos.",
  },
  {
    title: "Operación continua",
    body: "Para cargas permanentes o sitios remotos donde la energía no puede depender de la red pública.",
  },
  {
    title: "Proyectos temporales",
    body: "Obra, mantenimiento mayor, campamentos y eventos industriales con demanda acotada pero urgente.",
  },
  {
    title: "Expansión y modernización",
    body: "Cuando el cliente necesita crecer capacidad, mejorar transferencia o actualizar infraestructura existente.",
  },
];
const whatsappUrl = buildWhatsAppUrl("Hola, necesito una cotización para una solución de energía Generax.");

const schema = [
  organizationSchema(),
  websiteSchema(),
  webPageSchema({
    name: "Soluciones por industria | GENERAX",
    description: "Soluciones de energía de respaldo y operación continua por industria: manufactura, salud, hotelería, logística, construcción e infraestructura crítica.",
    path: "/soluciones/",
    image: "/media/Generadores-a-diesel-mexico-2-1536x1152-1.jpeg",
    speakableSelectors: [".page-hero h1", ".page-hero p"],
  }),
  breadcrumbSchema([
    { name: "Inicio", path: "/" },
    { name: "Soluciones", path: "/soluciones/" },
  ]),
  serviceSchema(
    "Soluciones por industria y criticidad",
    "Páginas de solución para manufactura, salud, hotelería, logística y proyectos industriales en México.",
    "/soluciones/",
  ),
];
---

<BaseLayout
  title="Soluciones por industria | GENERAX"
  description="Soluciones de energía de respaldo y operación continua por industria: manufactura, salud, hotelería, logística, construcción e infraestructura crítica."
  path="/soluciones/"
  image="/media/Generadores-a-diesel-mexico-2-1536x1152-1.jpeg"
  imageAlt="Instalación industrial de respaldo energético"
  schema={schema}
>
  <section class="page-hero">
    <div class="container page-hero__grid">
      <div class="page-hero__copy">
        <div class="breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>Soluciones</span>
        </div>
        <span class="hero__eyebrow">Soluciones por industria</span>
        <h1>Soluciones de energía por industria y tipo de operación.</h1>
        <p>
          Atendemos proyectos de respaldo, operación continua, expansión y necesidades temporales en sectores con alta
          exigencia operativa.
        </p>
        <div class="hero__actions">
          <a
            class="button button--primary"
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            data-whatsapp-context="soluciones-hero-primary"
          >
            Hablar por WhatsApp
          </a>
          <a class="button button--ghost" href="#sectores-generax">
            Ver sectores
          </a>
        </div>
      </div>

      <div class="page-hero__card hero__visual">
        <img
          src="/media/Generadores-a-diesel-mexico-2-1536x1152-1.jpeg"
          alt="Instalación industrial de respaldo energético"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section id="sectores-generax" class="section-block section-block--light light-surface">
    <div class="container">
      <SectionHeading
        eyebrow="Sectores"
        title="Sectores a los que damos servicio."
        intro="Cada sector requiere una lectura distinta de criticidad, transferencia, autonomía y continuidad operativa."
      />
      <div class="solution-grid">
        {
          industrySolutions.map((industry) => (
            <article class="content-panel">
              <h3>{industry.title}</h3>
              <p>{industry.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-block section-block--light light-surface">
    <div class="container content-grid">
      <article class="content-panel">
        <SectionHeading
          eyebrow="Tipo de operación"
          title="Necesidades frecuentes de energía."
          intro="Si aún no defines el equipo exacto, podemos partir del tipo de operación y del riesgo que implica una interrupción."
        />
        <div class="comparison-list">
          {
            solutionModes.map((mode) => (
              <article>
                <h3>{mode.title}</h3>
                <p>{mode.body}</p>
              </article>
            ))
          }
        </div>
      </article>

      <LeadForm
        compact={true}
        source="soluciones-sidebar"
        title="Hablar con un asesor por industria"
        intro="Cuéntanos tu sector, ciudad y necesidad para orientarte hacia la solución adecuada."
      />
    </div>
  </section>
</BaseLayout>
