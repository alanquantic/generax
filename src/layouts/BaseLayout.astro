---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import { navigation, siteConfig } from "../data/site";
import "../styles/global.css";

type SchemaInput = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  schema?: SchemaInput;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  path = "/",
  image = siteConfig.ogImage,
  imageAlt = title,
  ogType = "website",
  schema = [],
} = Astro.props;

const pageTitle = title.includes(siteConfig.name) ? title : `${title} | ${siteConfig.name}`;
const canonical = path.startsWith("http") ? path : new URL(path, siteConfig.url).toString();
const ogImage = image.startsWith("http") ? image : new URL(image, siteConfig.url).toString();
const schemaNodes = Array.isArray(schema) ? schema : [schema];
const gtmId = import.meta.env.PUBLIC_GTM_ID;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08111b" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {
      schemaNodes.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": schemaNodes,
          })}
        />
      )
    }
    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      (function captureAttribution() {
        const keys = ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content", "gclid", "fbclid"];
        const params = new URLSearchParams(window.location.search);
        const stored = JSON.parse(localStorage.getItem("generax_attribution") || "{}");
        const next = { ...stored };

        keys.forEach((key) => {
          const value = params.get(key);
          if (value) next[key] = value;
        });

        next.landing_path = window.location.pathname;
        next.referrer = document.referrer || stored.referrer || "";
        localStorage.setItem("generax_attribution", JSON.stringify(next));

        window.dataLayer.push({
          event: "generax_page_view",
          page_path: window.location.pathname,
          page_title: document.title,
          ...next,
        });
      })();

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest("[data-whatsapp-context]") : null;
        if (!target) return;

        window.dataLayer.push({
          event: "whatsapp_cta_click",
          page_path: window.location.pathname,
          context: target.getAttribute("data-whatsapp-context"),
          label: target.textContent?.trim() || "",
        });
      });
    </script>
    {
      gtmId && (
        <script
          is:inline
          define:vars={{ gtmId }}
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer', '${gtmId}');`}
        />
      )
    }
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }
    <div class="site-shell">
      <Header navigation={navigation} />
      <main>
        <slot />
      </main>
      <Footer navigation={navigation} />
      <WhatsAppFloat />
    </div>
  </body>
</html>
