---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqList from "../../components/FaqList.astro";
import LeadForm from "../../components/LeadForm.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buildWhatsAppUrl, transformerFaqs, transformerTypes } from "../../data/site";
import { breadcrumbSchema, faqSchema, organizationSchema, serviceSchema, webPageSchema, websiteSchema } from "../../data/schema";

const technicalBlocks = [
  { title: "Capacidad", body: "Desde 5 kVA hasta más de 3000 kVA según proyecto." },
  { title: "Configuración", body: "Monofásica o trifásica, delta, estrella y combinaciones específicas." },
  { title: "Construcción", body: "Núcleo de acero al silicio, bobinas de cobre y acabados anticorrosivos." },
  { title: "Normativa", body: "Diseño y especificación alineados a exigencias de proyecto, industria y seguridad." },
];
const whatsappUrl = buildWhatsAppUrl("Hola, necesito una cotización de un transformador Generax.");

const schema = [
  organizationSchema(),
  websiteSchema(),
  webPageSchema(
    "Transformadores industriales | GENERAX",
    "Venta y fabricación de transformadores eléctricos para distribución, pedestal, poste, tipo seco y proyectos especiales en México.",
    "/transformadores/",
    "CollectionPage",
  ),
  breadcrumbSchema([
    { name: "Inicio", path: "/" },
    { name: "Transformadores", path: "/transformadores/" },
  ]),
  serviceSchema(
    "Transformadores industriales y especiales",
    "Oferta B2B de transformadores para distribución, pedestal, poste, tipo seco y configuraciones especiales.",
    "/transformadores/",
  ),
  faqSchema(transformerFaqs),
];
---

<BaseLayout
  title="Transformadores industriales | GENERAX"
  description="Venta y fabricación de transformadores eléctricos para distribución, pedestal, poste, tipo seco y proyectos especiales en México."
  path="/transformadores/"
  image="/media/transformadores-generax-2.jpeg"
  imageAlt="Transformador Generax para soluciones industriales"
  schema={schema}
>
  <section class="page-hero">
    <div class="container page-hero__grid">
      <div class="page-hero__copy">
        <div class="breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>Transformadores</span>
        </div>
        <span class="hero__eyebrow">Transformadores eléctricos</span>
        <h1>Transformadores industriales para distribución y proyectos especiales.</h1>
        <p>
          Soluciones para industria, comercio, hospitales, centros logísticos y desarrollos que requieren transformación
          confiable y materiales de alta calidad.
        </p>
        <div class="hero__actions">
          <a
            class="button button--primary"
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            data-whatsapp-context="transformadores-hero-primary"
          >
            Cotizar por WhatsApp
          </a>
          <a class="button button--ghost" href="#tipos-transformadores">
            Ver opciones
          </a>
        </div>
        <ul class="clean-list">
          <li>Distribución, pedestal, poste, tipo seco y especiales a medida.</li>
          <li>Devanados de cobre, configuraciones monofásicas y trifásicas.</li>
          <li>Atención comercial para proyectos estándar y desarrollos especiales.</li>
        </ul>
      </div>

      <div class="page-hero__card hero__visual">
        <img
          src="/media/transformadores-generax-2.jpeg"
          alt="Transformador Generax para soluciones industriales"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section id="tipos-transformadores" class="section-block section-block--light light-surface">
    <div class="container">
        <SectionHeading
          eyebrow="Oferta técnica"
          title="Tipos de transformadores que cotizamos."
          intro="Cada solución responde a una necesidad distinta de instalación, seguridad, capacidad y ambiente de operación."
        />

      <div class="services-grid">
        {
          transformerTypes.map((type) => (
            <article class="content-panel">
              <h3>{type.title}</h3>
              <p>{type.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-block section-block--light light-surface">
    <div class="container content-grid">
      <article class="content-panel">
        <SectionHeading
          eyebrow="Características"
          title="Características técnicas clave."
          intro="Información útil para áreas de compras, mantenimiento, ingeniería y operación."
        />
        <div class="spec-grid">
          {
            technicalBlocks.map((block) => (
              <article>
                <strong>{block.title}</strong>
                <span>{block.body}</span>
              </article>
            ))
          }
        </div>
      </article>

      <LeadForm
        compact={true}
        source="transformadores-sidebar"
        title="Solicitar cotización de transformador"
        intro="Comparte capacidad, voltajes, tipo de instalación y condiciones del proyecto para atenderte mejor."
      />
    </div>
  </section>

  <section class="section-block section-block--light light-surface">
    <div class="container">
      <SectionHeading
        eyebrow="FAQ"
        title="Preguntas clave para esta vertical."
        intro="Resolvemos dudas comunes sobre materiales, especificación y fabricación a medida."
      />
      <FaqList items={transformerFaqs} />
    </div>
  </section>
</BaseLayout>
