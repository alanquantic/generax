---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {
    items.map((item, index) => (
      <details class="faq-item" open={index === 0}>
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))
  }
</div>
