---
import { buildWhatsAppUrl, siteConfig } from "../data/site";

interface Props {
  navigation: { href: string; label: string }[];
}

const { navigation } = Astro.props;
const pathname = Astro.url.pathname;
const phoneHref = `tel:${siteConfig.telephone.replace(/\D/g, "")}`;
const whatsappUrl = buildWhatsAppUrl();
---

<header class="site-header">
  <div class="site-topbar">
    <div class="container site-topbar__inner">
      <div class="site-topbar__items">
        <a href={phoneHref}>Tel. {siteConfig.telephone}</a>
        <a
          class="site-topbar__whatsapp"
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          data-whatsapp-context="topbar"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M14.33 13.54c-.2-.1-1.16-.57-1.34-.63-.18-.07-.31-.1-.44.1-.13.2-.5.63-.62.76-.12.13-.23.15-.43.05-.2-.1-.84-.31-1.61-1.01-.59-.53-.99-1.17-1.11-1.37-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.34.07-.13.03-.25-.01-.35-.05-.1-.43-1.05-.6-1.44-.16-.38-.32-.32-.44-.32h-.37c-.13 0-.35.05-.52.25-.18.2-.68.66-.68 1.63 0 .96.7 1.88.8 2.01.1.13 1.36 2.09 3.3 2.93.46.2.82.31 1.1.4.46.15.88.13 1.22.08.38-.06 1.16-.47 1.32-.93.16-.46.16-.85.12-.93-.05-.08-.18-.13-.38-.23Z"
            />
            <path
              fill="currentColor"
              d="M12.04 2.4A8.54 8.54 0 0 0 4.65 15.2L3.3 20l4.66-1.22a8.7 8.7 0 0 0 4 1h.03c4.72 0 8.56-3.84 8.57-8.56A8.52 8.52 0 0 0 12.04 2.4Zm0 15.6H12a7.13 7.13 0 0 1-3.63-.99l-.26-.16-2.78.73.74-2.72-.17-.28a7.11 7.11 0 1 1 6.14 3.42Z"
            />
          </svg>
          <span>{siteConfig.whatsappDisplay}</span>
        </a>
        <span class="site-topbar__location">México</span>
      </div>
      <span class="site-topbar__meta">Soluciones B2B para continuidad operativa</span>
    </div>
  </div>

  <div class="container">
    <div class="header-inner">
      <a href="/" class="brand-mark" aria-label="Ir al inicio de Generax">
        <span class="brand-mark__logo-wrap">
          <img class="brand-mark__logo" src={siteConfig.logo} alt="GENERAX Power" />
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Principal">
        {
          navigation.map((item) => (
            <a class:list={["nav-link", pathname === item.href && "is-active"]} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="header-actions">
        <a class="button button--ghost" href={phoneHref}>
          Llamar
        </a>
        <a
          class="button button--primary"
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          data-whatsapp-context="header-primary"
        >
          Solicitar cotización
        </a>
      </div>

      <details class="mobile-nav">
        <summary>Menú</summary>
        <div class="mobile-nav__panel">
          {
            navigation.map((item) => (
              <a class:list={["mobile-nav__link", pathname === item.href && "is-active"]} href={item.href}>
                {item.label}
              </a>
            ))
          }
          <div class="mobile-nav__actions">
            <a class="button button--ghost button--block" href={phoneHref}>
              Llamar
            </a>
            <a
              class="button button--primary button--block"
              href={whatsappUrl}
              target="_blank"
              rel="noreferrer"
              data-whatsapp-context="mobile-menu-primary"
            >
              Solicitar cotización
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>
