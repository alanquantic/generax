---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
}

const { eyebrow, title, intro, align = "left" } = Astro.props;
---

<div class:list={["section-heading", align === "center" && "section-heading--center"]}>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {intro && <p class="section-heading__intro">{intro}</p>}
</div>
