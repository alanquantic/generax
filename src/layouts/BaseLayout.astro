---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import { navigation, siteConfig } from "../data/site";
import "../styles/global.css";

type SchemaInput = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  schema?: SchemaInput;
  datePublished?: string;
  dateModified?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  path = "/",
  image = siteConfig.ogImage,
  imageAlt = title,
  ogType = "website",
  schema = [],
  datePublished = "2025-01-01",
  dateModified,
} = Astro.props;

const pageTitle = title.includes(siteConfig.name) ? title : `${title} | ${siteConfig.name}`;
const canonical = path.startsWith("http") ? path : new URL(path, siteConfig.url).toString();
const ogImage = image.startsWith("http") ? image : new URL(image, siteConfig.url).toString();
const schemaNodes = Array.isArray(schema) ? schema : [schema];
const gtmId = import.meta.env.PUBLIC_GTM_ID;
const isoModified = dateModified || new Date().toISOString().slice(0, 10);
---

<!doctype html>
<html lang="es-MX" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="5xzN0oulBiL_se11NxI9rnJ9WpnOC5GevM-bvrTcZTo" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08111b" />
    <meta name="color-scheme" content="dark light" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="bingbot" content="index,follow" />
    <meta name="author" content={siteConfig.legalName} />
    <meta name="publisher" content={siteConfig.legalName} />
    <meta name="copyright" content={`© ${new Date().getFullYear()} ${siteConfig.legalName}`} />
    <meta name="geo.region" content="MX-NLE" />
    <meta name="geo.placename" content="Monterrey" />
    <meta name="geo.position" content="25.6866;-100.3161" />
    <meta name="ICBM" content="25.6866, -100.3161" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es-MX" href={canonical} />
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.legalName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:updated_time" content={isoModified} />
    <meta property="article:publisher" content={siteConfig.url} />
    <meta property="article:published_time" content={datePublished} />
    <meta property="article:modified_time" content={isoModified} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:site" content="@generaxpower" />
    {
      schemaNodes.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": schemaNodes,
          })}
        />
      )
    }

    <!-- Google tag (gtag.js) — GA4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MJF9L16MPS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      (function () {
        var path = window.location.pathname;
        var cg = 'other';
        if (path === '/') cg = 'home';
        else if (path.startsWith('/generadores/') && path !== '/generadores/') cg = 'product-detail';
        else if (path.startsWith('/generadores')) cg = 'generators';
        else if (path.startsWith('/transformadores')) cg = 'transformers';
        else if (path.startsWith('/soluciones')) cg = 'solutions';
        else if (path.startsWith('/servicios')) cg = 'services';
        else if (path.startsWith('/contacto')) cg = 'contact';
        else if (path.startsWith('/empresa')) cg = 'about';
        else if (path.startsWith('/tienda')) cg = 'store';

        window.__gxContentGroup = cg;

        gtag('config', 'G-MJF9L16MPS', {
          content_group: cg,
          send_page_view: false
        });

        /* ── Attribution capture ── */
        var keys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','gclid','fbclid'];
        var params = new URLSearchParams(window.location.search);
        var stored = JSON.parse(localStorage.getItem('generax_attribution') || '{}');
        var next = Object.assign({}, stored);

        keys.forEach(function (k) { var v = params.get(k); if (v) next[k] = v; });
        next.landing_path = path;
        next.referrer = document.referrer || stored.referrer || '';
        localStorage.setItem('generax_attribution', JSON.stringify(next));

        dataLayer.push({
          event: 'generax_page_view',
          page_path: path,
          page_title: document.title,
          utm_source: next.utm_source || '',
          utm_medium: next.utm_medium || '',
          utm_campaign: next.utm_campaign || '',
          utm_term: next.utm_term || '',
          utm_content: next.utm_content || '',
          gclid: next.gclid || '',
          fbclid: next.fbclid || '',
          landing_path: next.landing_path || '',
          referrer: next.referrer || ''
        });

        gtag('event', 'page_view', {
          page_title: document.title,
          page_location: window.location.href,
          page_path: path,
          content_group: cg,
          campaign_source: next.utm_source || '(direct)',
          campaign_medium: next.utm_medium || '(none)',
          campaign_name: next.utm_campaign || ''
        });

        /* ── WhatsApp CTA clicks (conversion) ── */
        document.addEventListener('click', function (e) {
          var t = e.target instanceof Element ? e.target.closest('[data-whatsapp-context]') : null;
          if (!t) return;
          var ctx = t.getAttribute('data-whatsapp-context') || '';
          var txt = (t.textContent || '').trim();

          dataLayer.push({ event: 'whatsapp_cta_click', page_path: path, context: ctx, label: txt });
          gtag('event', 'whatsapp_cta_click', {
            event_category: 'conversion',
            event_label: ctx,
            cta_context: ctx,
            cta_text: txt,
            page_path: path,
            content_group: cg
          });
        });

        /* ── Phone clicks (conversion) ── */
        document.addEventListener('click', function (e) {
          var t = e.target instanceof Element ? e.target.closest('a[href^="tel:"]') : null;
          if (!t) return;
          var phone = t.getAttribute('href') || '';

          dataLayer.push({ event: 'phone_click', page_path: path, phone_number: phone });
          gtag('event', 'phone_click', {
            event_category: 'conversion',
            event_label: phone,
            link_text: (t.textContent || '').trim(),
            page_path: path,
            content_group: cg
          });
        });

        /* ── FAQ expand (engagement) ── */
        document.addEventListener('toggle', function (e) {
          var el = e.target;
          if (!el || !el.classList || !el.classList.contains('faq-item') || !el.open) return;
          var q = el.querySelector('summary');
          var question = q ? q.textContent.trim() : '';

          dataLayer.push({ event: 'faq_expand', page_path: path, question: question });
          gtag('event', 'faq_expand', {
            event_category: 'engagement',
            event_label: question,
            page_path: path,
            content_group: cg
          });
        }, true);

        /* ── Scroll depth milestones ── */
        (function () {
          var milestones = [25, 50, 75, 90];
          var fired = {};
          var timer;
          function check() {
            var st = window.pageYOffset || document.documentElement.scrollTop;
            var dh = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            if (dh <= 0) return;
            var pct = Math.round(st / dh * 100);
            milestones.forEach(function (m) {
              if (pct >= m && !fired[m]) {
                fired[m] = true;
                dataLayer.push({ event: 'scroll_depth', percent_scrolled: m, page_path: path });
                gtag('event', 'scroll_depth', {
                  event_category: 'engagement',
                  percent_scrolled: m,
                  page_path: path,
                  content_group: cg
                });
              }
            });
          }
          window.addEventListener('scroll', function () {
            clearTimeout(timer);
            timer = setTimeout(check, 150);
          }, { passive: true });
        })();

        /* ── Internal CTA clicks (engagement) ── */
        document.addEventListener('click', function (e) {
          var t = e.target instanceof Element
            ? e.target.closest('a.button:not([data-whatsapp-context]):not([href^="tel:"])')
            : null;
          if (!t) return;
          var href = t.getAttribute('href') || '';
          if (href.startsWith('http') && href.indexOf(window.location.hostname) === -1) return;

          dataLayer.push({ event: 'cta_click', page_path: path, cta_text: (t.textContent || '').trim(), destination_url: href });
          gtag('event', 'cta_click', {
            event_category: 'engagement',
            event_label: (t.textContent || '').trim(),
            destination_url: href,
            page_path: path,
            content_group: cg
          });
        });
      })();
    </script>
    {
      gtmId && (
        <script
          is:inline
          define:vars={{ gtmId }}
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer', '${gtmId}');`}
        />
      )
    }
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }
    <div class="site-shell">
      <Header navigation={navigation} />
      <main>
        <slot />
      </main>
      <Footer navigation={navigation} />
      <WhatsAppFloat />
    </div>
  </body>
</html>
